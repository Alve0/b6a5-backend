<!DOCTYPE html>
<html>
  <head>
    <title>Reset Your Password</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        background: #2196f3;
        color: white;
        padding: 20px;
        text-align: center;
      }
      .content {
        padding: 20px;
        background: #f9f9f9;
      }
      .button {
        display: inline-block;
        padding: 10px 20px;
        background: #2196f3;
        color: white;
        text-decoration: none;
        border-radius: 5px;
      }
      .footer {
        padding: 20px;
        text-align: center;
        font-size: 12px;
        color: #666;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>Password Reset</h1>
      </div>
      <div class="content">
        <h2>Hello <%= user.name || 'User' %>!</h2>
        <p>You requested a password reset for your Apollo Gears account.</p>
        <p>Click the button below to reset your password:</p>
        <a
          href="<%= process.env.BASE_URL %>/api/v1/auth/reset-password?token=<%= token %>"
          class="button"
          >Reset Password</a
        >
        <p>
          If the button doesn't work, you can copy and paste this link into your
          browser:
        </p>
        <p>
          <%= process.env.BASE_URL %>/api/v1/auth/reset-password?token=<%= token
          %>
        </p>
        <p>This link will expire in 10 minutes for security reasons.</p>
        <p>
          If you didn't request this password reset, please ignore this email.
        </p>
      </div>
      <div class="footer">
        <p>&copy; 2024 Apollo Gears. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>
